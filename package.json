{
  "name": "node-scim",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "author": {
    "name": "Michael Nahkies",
    "email": "support@nahkies.co.nz"
  },
  "scripts": {
    "postinstall": "husky install",
    "generate": "./scripts/generate.sh",
    "build": "tsc -p ./tsconfig.json",
    "lint": "biome check --write .",
    "test": "vitest run",
    "dev": "pnpm run build && dotenvx run -f .env -- node ./dist/api.entrypoint.js",
    "watch:openapi": "nodemon --watch ./openapi.yaml --watch ./docs/openapi -e yaml --exec './scripts/generate.sh'",
    "watch:dev": "nodemon --watch ./src -e ts --delay 2 --exec 'pnpm run dev'",
    "clean:users": "dotenvx run -f .env -- tsx ./scripts/clean-users.ts",
    "ci-build": "pnpm run generate && pnpm run build",
    "ci-test": "vitest run --coverage",
    "ci-lint": "biome ci --error-on-warnings .",
    "ci-pipeline": "pnpm run generate && pnpm run build && pnpm run test && pnpm run lint"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.6.0",
    "@nahkies/typescript-koa-runtime": "^0.26.0",
    "base-x": "^5.0.1",
    "co-body": "^6.2.0",
    "diod": "^3.0.0",
    "firebase-admin": "^14.0.0",
    "getenv": "^2.0.0",
    "koa": "^3.0.0",
    "koa-body": "^7.0.1",
    "reflect-metadata": "^0.2.2",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@dotenvx/dotenvx": "^1.48.3",
    "@nahkies/openapi-code-generator": "^0.26.0",
    "@tsconfig/node24": "^24.0.1",
    "@tsconfig/strictest": "^2.0.5",
    "@types/co-body": "^6.1.3",
    "@types/getenv": "^1.0.3",
    "@types/koa": "^3.0.3",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "nodemon": "^3.1.10",
    "peggy": "^5.0.5",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
